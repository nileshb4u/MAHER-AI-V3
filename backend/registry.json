        "timeout": 45,
        "priority": 2,
        "dependencies": [],
        "status": "published",
        "tool_schema": {
          "type": "function",
          "function": {
            "name": "analyze_incident_report",
            "description": "Analyzes a maintenance or safety incident report to extract root causes, contributing factors, and corrective action recommendations. Use when the user describes an incident, failure, or near-miss.",
            "parameters": {
              "type": "object",
              "properties": {
                "incident_description": {
                  "type": "string",
                  "description": "Full description of the incident including what happened, when, where, and equipment involved"
