      {
        "id": "workflow_maintenance_checklist",
        "name": "Maintenance Checklist Generator",
        "description": "Generates comprehensive maintenance checklists based on equipment type and maintenance level",
        "capabilities": ["maintenance_planning", "checklist_generation", "equipment_procedures"],
        "module_path": "workflows.maintenance_checklist",
        "function": "generate_checklist",
        "parameters": {
          "equipment_type": "string",
          "maintenance_level": "string (routine|preventive|corrective)"
        },
        "execution_type": "async",
        "timeout": 30,
        "priority": 2,
        "dependencies": [],
        "status": "published",
        "tool_schema": {
          "type": "function",
          "function": {
            "name": "generate_maintenance_checklist",
            "description": "Generates a comprehensive step-by-step maintenance checklist for a piece of equipment. Use this when the user asks for a maintenance checklist, procedure list, or inspection steps.",
            "parameters": {
              "type": "object",
              "properties": {
                "equipment_type": {
                  "type": "string",
                  "description": "Type of equipment (e.g. centrifugal pump, gas compressor, heat exchanger, motor)"
                },
                "maintenance_level": {
                  "type": "string",
                  "enum": ["routine", "preventive", "corrective"],
                  "description": "Level of maintenance: routine (daily checks), preventive (scheduled), corrective (after failure)"
                }
              },
              "required": ["equipment_type", "maintenance_level"]
            }
          }
        }
      },
      {
        "id": "workflow_incident_analyzer",
        "name": "Incident Report Analyzer",
        "description": "Analyzes incident reports and extracts key information, root causes, and recommendations",
        "capabilities": ["incident_analysis", "root_cause_analysis", "safety_recommendations"],
        "module_path": "workflows.incident_analyzer",
