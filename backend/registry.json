                "equipment_id": {
                  "type": "string",
                  "description": "Equipment tag or ID involved in the incident (optional)"
                },
                "severity": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "critical"],
                  "description": "Reported severity of the incident"
                }
              },
              "required": ["incident_description"]
            }
          }
        }
      },
